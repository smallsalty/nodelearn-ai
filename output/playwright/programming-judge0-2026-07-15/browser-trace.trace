e530]:\n                - strong [ref=f2e531]: 双向队列\n                - generic [ref=f2e532]: 5 个子节点\n            - button \"二叉树数组表示 7 个子节点\" [ref=f2e537] [cursor=pointer]:\n              - generic [ref=f2e543]:\n                - strong [ref=f2e544]: 二叉树数组表示\n                - generic [ref=f2e545]: 7 个子节点\n    - generic [ref=f2e173]:\n      - generic [ref=f2e174]:\n        - generic [ref=f2e176]:\n          - paragraph [ref=f2e177]: NodeLearn 学习平台\n          - heading \"编程题\" [level=1] [ref=f2e178]\n        - generic [ref=f2e179]:\n          - generic [ref=f2e181]:\n            - generic:\n              - combobox \"选择课程\" [ref=f2e183]\n              - generic [ref=f2e184]: Hello 算法\n          - generic [ref=f2e190]:\n            - generic:\n              - combobox \"选择知识点\" [ref=f2e192]\n              - generic [ref=f2e193]: 附录\n          - generic [ref=f2e198]: demo_student\n          - button \"Hello 算法 附录\" [ref=f2e549] [cursor=pointer]:\n            - generic [ref=f2e203]:\n              - strong [ref=f2e204]: Hello 算法\n              - generic [ref=f2e205]: 附录\n          - button \"退出\" [ref=f2e206] [cursor=pointer]\n      - main [ref=f2e212]:\n        - generic [ref=f2e213]:\n          - generic [ref=f2e214]:\n            - generic [ref=f2e215]:\n              - generic [ref=f2e216]:\n                - heading \"编程题\" [level=2] [ref=f2e217]\n                - paragraph [ref=f2e218]: 选择知识点生成题目，使用标准输入输出完成代码并提交判题。\n              - button \"刷新\" [ref=f2e550] [cursor=pointer]\n            - generic [ref=f2e220]:\n              - generic [ref=f2e221]:\n                - generic [ref=f2e222]:\n                  - generic [ref=f2e223]: 知识点\n                  - generic [ref=f2e226]:\n                    - generic:\n                      - combobox \"知识点\" [ref=f2e228]\n                      - generic [ref=f2e229]: 附录\n                - generic [ref=f2e234]:\n                  - generic [ref=f2e235]: 难度\n                  - generic [ref=f2e238] [cursor=pointer]:\n                    - generic:\n                      - combobox \"难度\" [ref=f2e240]\n                      - generic [ref=f2e241]: 中等\n              - button \"生成编程题\" [ref=f2e246] [cursor=pointer]\n            - article [ref=f2e552]:\n              - generic [ref=f2e553]:\n                - generic [ref=f2e554]: 编程题\n                - generic [ref=f2e556]: 基础\n                - generic [ref=f2e558]: 2 秒\n              - heading \"循环左移数组\" [level=3] [ref=f2e560]\n              - paragraph [ref=f2e561]: 给定一个包含n个整数的数组，将其循环左移一位后输出。\n              - heading \"输入格式\" [level=4] [ref=f2e562]\n              - paragraph [ref=f2e563]: 第一行一个整数n（1 ≤ n ≤ 1000），表示数组长度。 第二行n个整数，用空格分隔，表示数组元素。\n              - heading \"输出格式\" [level=4] [ref=f2e564]\n              - paragraph [ref=f2e565]: 一行，包含n个整数，表示循环左移一位后的数组，用空格分隔，末尾有换行。\n              - heading \"约束\" [level=4] [ref=f2e566]\n              - paragraph [ref=f2e567]: 1 ≤ n ≤ 1000; 每个数组元素的绝对值 ≤ 10000。\n              - heading \"样例\" [level=4] [ref=f2e568]\n              - article [ref=f2e569]:\n                - strong [ref=f2e570]: 输入\n                - generic [ref=f2e571]: 5 1 2 3 4 5\n                - strong [ref=f2e572]: 输出\n                - generic [ref=f2e573]: 2 3 4 5 1\n              - generic [ref=f2e574]:\n                - generic [ref=f2e575]: 编程语言\n                - radiogroup \"编程语言\" [ref=f2e577]:\n                  - generic [ref=f2e578]:\n                    - radio \"C++\" [ref=f2e579]\n                    - generic [ref=f2e580] [cursor=pointer]: C++\n                  - generic [ref=f2e581]:\n                    - radio \"C\" [ref=f2e582]\n                    - generic [ref=f2e583] [cursor=pointer]: C\n                  - generic [ref=f2e584]:\n                    - radio \"Python\" [checked] [ref=f2e585]\n                    - generic [ref=f2e586] [cursor=pointer]: Python\n              - textbox [ref=f2e588]: s=__import__('sys');d=list(map(int,s.stdin.read().split()));n=d[0];a=d[1:1+n];print(*(a[1:]+a[:1]))\n              - button \"运行并判题\" [ref=f2e590] [cursor=pointer]\n              - generic [ref=f2e595]:\n                - paragraph [ref=f2e600]: AC\n                - paragraph [ref=f2e602]: 全部公开与隐藏测试用例通过。\n          - complementary [ref=f2e259]:\n            - generic [ref=f2e260]:\n              - generic [ref=f2e261]: 本次题目\n              - button \"循环左移数组 基础\" [ref=f2e592] [cursor=pointer]:\n                - strong [ref=f2e593]: 循环左移数组\n                - generic [ref=f2e594]: 基础\n  - button [ref=f2e283] [cursor=pointer]"}}
